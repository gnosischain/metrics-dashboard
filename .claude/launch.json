{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js"],
      "port": 5173
    },
    {
      "name": "dev-preview-5390",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--port", "5390", "--strictPort"],
      "port": 5390
    },
    {
      "name": "dev-proxy-3000",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--port", "5174"],
      "port": 5174,
      "env": {
        "VITE_DEV_API_PROXY_TARGET": "http://localhost:3000"
      }
    },
    {
      "name": "vercel",
      "runtimeExecutable": "vercel",
      "runtimeArgs": ["dev", "--listen", "3000"],
      "port": 3000
    }
  ]
}
